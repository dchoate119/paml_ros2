<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro" name="ur3e_with_camera">

  <!-- Arguments passed through to the official UR xacro -->
  <xacro:arg name="name" default="ur"/>
  <xacro:arg name="ur_type" default="ur3e"/>
  <xacro:arg name="tf_prefix" default=""/>

  <!-- Load the normal UR robot model -->
  <xacro:include filename="$(find ur_description)/urdf/ur.urdf.xacro"/>

  <xacro:ur_robot
    name="$(arg name)"
    ur_type="$(arg ur_type)"
    tf_prefix="$(arg tf_prefix)"
  />

  <!-- Simple collision/visual geometry for RGBD camera or mount -->
  <link name="rgbd_camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.06 0.05"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.06 0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="rgbd_camera_joint" type="fixed">
    <parent link="tool0"/>
    <child link="rgbd_camera_link"/>

    <!-- Placeholder: adjust this to match the actual mount -->
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
  </joint>

</robot>